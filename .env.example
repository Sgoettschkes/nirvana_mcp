# Application identifier registered with NirvanaHQ (required on every request).
NIRVANA_APP_ID=

# Pre-computed auth token (MD5-derived). Preferred over storing the password.
NIRVANA_AUTH_TOKEN=

# Fallback: username + password. Used only if NIRVANA_AUTH_TOKEN is empty;
# the client will derive the token on startup.
NIRVANA_USERNAME=
NIRVANA_PASSWORD=
